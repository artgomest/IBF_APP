<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================== -->
    <!--   IBF APP - Light Theme (Base)              -->
    <!-- =========================================== -->

    <style name="Theme.IBFAPP" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/near_black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ibf_surface_variant</item>
        <item name="colorOnPrimaryContainer">@color/near_black</item>
        <item name="colorSecondary">@color/chumbo_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/ibf_surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/near_black</item>
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/accent_container</item>
        <item name="colorOnTertiaryContainer">@color/near_black</item>
        <item name="android:colorBackground">@color/ibf_background</item>
        <item name="colorSurface">@color/ibf_surface</item>
        <item name="colorOnSurface">@color/ibf_on_surface</item>
        <item name="colorSurfaceVariant">@color/ibf_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/ibf_on_surface_variant</item>
        <item name="colorOutline">@color/ibf_outline</item>
        <item name="colorOutlineVariant">@color/ibf_outline_variant</item>
        <item name="colorError">@color/ibf_error</item>
        <item name="colorOnError">@color/ibf_on_error</item>
        <item name="colorErrorContainer">@color/ibf_error_container</item>
        <item name="android:statusBarColor">@color/ibf_background</item>
        <item name="android:navigationBarColor">@color/ibf_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/ibf_background</item>
    </style>

    <!-- =========================================== -->
    <!--   IBF APP - Dark Theme (Night override)     -->
    <!-- =========================================== -->

    <style name="Theme.IBFAPP.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/off_white</item>
        <item name="colorOnPrimary">@color/near_black</item>
        <item name="colorPrimaryContainer">@color/chumbo_dark</item>
        <item name="colorOnPrimaryContainer">@color/off_white</item>
        <item name="colorSecondary">@color/chumbo_faint</item>
        <item name="colorOnSecondary">@color/near_black</item>
        <item name="colorSecondaryContainer">@color/chumbo_dark</item>
        <item name="colorOnSecondaryContainer">@color/off_white</item>
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">#1B3A2A</item>
        <item name="colorOnTertiaryContainer">@color/off_white</item>
        <item name="android:colorBackground">@color/ibf_background</item>
        <item name="colorSurface">@color/ibf_surface</item>
        <item name="colorOnSurface">@color/ibf_on_surface</item>
        <item name="colorSurfaceVariant">@color/ibf_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/ibf_on_surface_variant</item>
        <item name="colorOutline">@color/ibf_outline</item>
        <item name="colorOutlineVariant">@color/ibf_outline_variant</item>
        <item name="colorError">@color/ibf_error</item>
        <item name="colorOnError">@color/ibf_on_error</item>
        <item name="colorErrorContainer">@color/ibf_error_container</item>
        <item name="android:statusBarColor">@color/ibf_background</item>
        <item name="android:navigationBarColor">@color/ibf_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/ibf_background</item>
    </style>

    <!-- =========================================== -->
    <!--   Reusable Component Styles                 -->
    <!-- =========================================== -->

    <!-- Base styles (required for dot-notation inheritance) -->
    <style name="IBF" parent="" />
    <style name="IBF.Text" parent="IBF" />

    <!-- Cards -->
    <style name="IBF.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

    <style name="IBF.Card.Elevated" parent="IBF.Card">
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="IBF.Card.Accent" parent="IBF.Card">
        <item name="cardBackgroundColor">@color/near_black</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Buttons -->
    <style name="IBF.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/near_black</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/btn_height_md</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="IBF.Button.Accent" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/btn_height_md</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="IBF.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/btn_height_md</item>
    </style>

    <style name="IBF.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="IBF.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_sm</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_sm</item>
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="IBF.TextInputLayout.Rounded" parent="IBF.TextInputLayout">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
    </style>

    <!-- Typography -->
    <style name="IBF.Text.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="IBF.Text.HeadlineLg">
        <item name="android:textSize">@dimen/text_headline_lg</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="IBF.Text.HeadlineMd">
        <item name="android:textSize">@dimen/text_headline_md</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="IBF.Text.TitleLg">
        <item name="android:textSize">@dimen/text_title_lg</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="IBF.Text.TitleMd">
        <item name="android:textSize">@dimen/text_title_md</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="IBF.Text.Body">
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="IBF.Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="IBF.Text.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Divider -->
    <style name="IBF.Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">?attr/colorOutlineVariant</item>
    </style>

    <!-- =========================================== -->
    <!--   Legacy styles (compatibilidade)           -->
    <!-- =========================================== -->

    <style name="DashboardCard" parent="IBF.Card" />

    <style name="DashboardCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/card_padding</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="DashboardCardTitle" parent="IBF.Text.TitleLg" />

    <style name="GraficoCard" parent="IBF.Card" />
    <style name="GraficoChart" />
    <style name="GraficoContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>
    <style name="GraficoTitle" parent="IBF.Text.TitleLg" />
    <style name="GraficoTitle.Small" parent="IBF.Text.TitleMd" />
    <style name="GraficoValor" parent="IBF.Text.Display" />

    <style name="formLabel" parent="IBF.Text.Caption">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <style name="formEditText" parent="IBF.TextInputLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="LoginEditText" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">14dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">@drawable/edit_text_background</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

</resources>
