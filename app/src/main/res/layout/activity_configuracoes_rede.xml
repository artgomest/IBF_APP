<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.configuracoes.ConfiguracoesRedeActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_sm">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl"
            android:src="@drawable/ic_arrow_back"
            android:padding="@dimen/space_sm"
            android:contentDescription="@string/voltar"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorOnBackground" />

        <TextView
            android:id="@+id/text_page_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/configuracoes_da_rede"
            android:textColor="?attr/colorOnBackground"
            android:textSize="@dimen/text_headline_md"
            android:textStyle="bold" />

        <View
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_md">

        <!-- Rede atual label -->
        <TextView
            android:id="@+id/text_rede_atual_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rede_selecionada_label"
            android:textSize="@dimen/text_body_md"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Card: Usuários -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_usuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            style="@style/IBF.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_user_group"
                    android:contentDescription="@string/icone_usuarios_content_description"
                    app:tint="?attr/colorOnBackground"
                    android:layout_marginEnd="@dimen/space_md" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/usuarios"
                    android:textSize="@dimen/text_title_lg"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Configurações da rede -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rede_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/IBF.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_settings_gear"
                    android:contentDescription="@string/icone_rede_content_description"
                    app:tint="?attr/colorOnBackground"
                    android:layout_marginEnd="@dimen/space_md" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/rede_config"
                    android:textSize="@dimen/text_title_lg"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</LinearLayout>
