<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh_layout_solicitacoes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.usuarios.fragments.SolicitacoesPendentesFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_solicitacoes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_xl"
        android:clipToPadding="false"
        tools:listitem="@layout/item_solicitacao_pendente" />

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
