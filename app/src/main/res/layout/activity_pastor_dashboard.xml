<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".ui.dashboard.PastorDashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="56dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Olá,"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/text_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ola_pastor_nome_placeholder"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visão Geral da Igreja"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/image_profile"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_profile_placeholder"
                android:contentDescription="@string/profile_image_content_description"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_icon_container"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Conteúdo scrollável -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <!-- =============================== -->
                    <!-- RESUMO GERAL - Cards de métricas -->
                    <!-- =============================== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <!-- Card: Total de Redes -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            app:cardBackgroundColor="?attr/colorOnBackground"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Redes"
                                    android:textSize="11sp"
                                    android:textColor="@color/chumbo_faint"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.05" />

                                <TextView
                                    android:id="@+id/text_total_redes"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:layout_marginTop="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ativas"
                                    android:textSize="12sp"
                                    android:textColor="@color/chumbo_faint" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card: Total de Membros -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="5dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Membros"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.05" />

                                <TextView
                                    android:id="@+id/text_total_membros"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:layout_marginTop="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="cadastrados"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card: Presença Média -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            app:cardBackgroundColor="?attr/colorSurface"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Presença"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.05" />

                                <TextView
                                    android:id="@+id/text_presenca_media"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/accent"
                                    android:layout_marginTop="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="média/culto"
                                    android:textSize="12sp"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- =============================== -->
                    <!-- OFERTAS SEÇÃO -->
                    <!-- =============================== -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:layout_marginTop="4dp"
                        app:cardBackgroundColor="@color/accent"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ofertas (últimas 8 semanas)"
                                    android:textSize="12sp"
                                    android:textColor="#B3FFFFFF" />

                                <TextView
                                    android:id="@+id/text_total_ofertas"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R$ 0,00"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Visitantes"
                                    android:textSize="12sp"
                                    android:textColor="#B3FFFFFF" />

                                <TextView
                                    android:id="@+id/text_total_visitantes"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- =============================== -->
                    <!-- STATUS DAS REDES -->
                    <!-- =============================== -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS DAS REDES"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="10dp" />

                    <!-- Container dinâmico para cards de rede -->
                    <LinearLayout
                        android:id="@+id/container_redes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- =============================== -->
                    <!-- AÇÕES RÁPIDAS -->
                    <!-- =============================== -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AÇÕES RÁPIDAS"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Agenda -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_agenda"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="18dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_container_green"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@color/accent" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Agenda"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Reuniões e discipulados"
                                    android:textSize="13sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="?attr/colorOnSurfaceVariant" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mudar Perfil -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_mudar_perfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="18dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/colorSurfaceVariant"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_change_account"
                                    app:tint="?attr/colorOnSurface" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mudar perfil"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginStart="16dp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="?attr/colorOnSurfaceVariant" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </ScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            app:itemIconTint="@color/bottom_nav_item_color"
            app:itemTextColor="@color/bottom_nav_item_color"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
