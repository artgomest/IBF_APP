<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.configuracoes.EditarRedeActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_sm">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl"
            android:src="@drawable/ic_arrow_back"
            android:padding="@dimen/space_sm"
            android:contentDescription="@string/voltar"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/colorOnBackground" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/editar_rede_titulo"
            android:textColor="?attr/colorOnBackground"
            android:textSize="@dimen/text_headline_md"
            android:textStyle="bold" />

        <View
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_md">

        <!-- Nome da rede -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/IBF.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/editar_rede_nome_hint"
            android:layout_marginBottom="@dimen/space_md">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_nome_rede"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dia da semana label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/editar_rede_dia_label"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_md"
            android:layout_marginBottom="@dimen/space_sm" />

        <!-- Spinner dia da semana -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            style="@style/IBF.Card">

            <Spinner
                android:id="@+id/spinner_dia_semana"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/spinner_background"
                android:minHeight="52dp"
                android:spinnerMode="dropdown"
                android:padding="@dimen/space_md" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_salvar_rede"
            android:layout_width="match_parent"
            android:layout_height="@dimen/btn_height_md"
            android:text="@string/salvar_alteracoes"
            style="@style/IBF.Button.Primary" />

    </LinearLayout>
</LinearLayout>
