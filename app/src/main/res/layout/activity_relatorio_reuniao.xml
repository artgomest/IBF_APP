<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                android:padding="4dp"
                android:contentDescription="Voltar"
                app:tint="@color/dark_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Relatório do Discipulado"
                android:textColor="@color/dark_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Meeting info (read-only) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/dark_card_background"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/text_info_membro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Membro"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/text_info_data"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data e Hora"
                    android:textColor="@color/dark_text_secondary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tabs: Texto | Áudio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tab_texto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Resumo em Texto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/dark_accent"
                app:strokeColor="@color/dark_accent"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tab_audio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Resumo em Áudio"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/dark_text_secondary"
                app:strokeColor="@color/dark_text_secondary"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Text section -->
        <LinearLayout
            android:id="@+id/section_texto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Resumo do discipulado"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/dark_accent"
                app:hintTextColor="@color/dark_text_secondary"
                app:boxBackgroundColor="@color/dark_card_background">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_resumo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:gravity="top|start"
                    android:textColor="@color/dark_text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Audio section -->
        <LinearLayout
            android:id="@+id/section_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <!-- Timer display -->
            <TextView
                android:id="@+id/text_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="02:00"
                android:textColor="@color/dark_text_primary"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Progress bar showing remaining time -->
            <ProgressBar
                android:id="@+id/progress_audio"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="120"
                android:progress="120"
                android:progressTint="@color/dark_accent"
                android:progressBackgroundTint="@color/dark_card_background"
                android:layout_marginBottom="16dp" />

            <!-- Record / Stop buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_gravar_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="Gravar"
                    android:backgroundTint="@color/dark_accent"
                    app:icon="@drawable/ic_mic"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_parar_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parar"
                    android:enabled="false"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/status_red_dark_theme"
                    app:strokeColor="@color/status_red_dark_theme"
                    app:cornerRadius="8dp" />

            </LinearLayout>

            <!-- Audio status text -->
            <TextView
                android:id="@+id/text_audio_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Aguardando gravação..."
                android:textColor="@color/dark_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_salvar_relatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Salvar Relatório"
            android:backgroundTint="@color/dark_accent"
            android:textColor="@color/white"
            app:icon="@drawable/ic_save"
            app:cornerRadius="8dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
