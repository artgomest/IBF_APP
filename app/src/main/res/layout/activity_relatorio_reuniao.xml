<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/space_sm">

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="@dimen/icon_xl"
                android:layout_height="@dimen/icon_xl"
                android:src="@drawable/ic_arrow_back"
                android:padding="@dimen/space_sm"
                android:contentDescription="@string/voltar"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Relatório do Discipulado"
                android:textColor="?attr/colorOnBackground"
                android:textSize="@dimen/text_headline_md"
                android:textStyle="bold" />

            <View
                android:layout_width="@dimen/icon_xl"
                android:layout_height="@dimen/icon_xl" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/space_xl">

            <!-- Meeting info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                style="@style/IBF.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/text_info_membro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Membro"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_title_lg"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/space_xs" />

                    <TextView
                        android:id="@+id/text_info_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data e Hora"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_body_md" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tab selector: Texto | Áudio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_md">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tab_texto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_xs"
                    android:text="Resumo em Texto"
                    style="@style/IBF.Button.Primary"
                    app:cornerRadius="@dimen/radius_sm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tab_audio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_xs"
                    android:text="Resumo em Áudio"
                    style="@style/IBF.Button.Secondary"
                    app:cornerRadius="@dimen/radius_sm" />
            </LinearLayout>

            <!-- Text section -->
            <LinearLayout
                android:id="@+id/section_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/space_md">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Resumo do discipulado"
                    style="@style/IBF.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_resumo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="5"
                        android:gravity="top|start"
                        android:textColor="?attr/colorOnSurface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Audio section -->
            <LinearLayout
                android:id="@+id/section_audio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/space_md"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="02:00"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/space_sm" />

                <ProgressBar
                    android:id="@+id/progress_audio"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="120"
                    android:progress="120"
                    android:progressTint="@color/accent"
                    android:progressBackgroundTint="?attr/colorSurfaceVariant"
                    android:layout_marginBottom="@dimen/space_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/space_sm">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_gravar_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_sm"
                        android:text="Gravar"
                        style="@style/IBF.Button.Accent"
                        app:icon="@drawable/ic_mic" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_parar_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parar"
                        android:enabled="false"
                        style="@style/IBF.Button.Secondary"
                        app:strokeColor="@color/ibf_error"
                        android:textColor="@color/ibf_error" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_audio_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Aguardando gravação..."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_body_md" />
            </LinearLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_salvar_relatorio"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_md"
                android:text="Salvar Relatório"
                android:layout_marginTop="@dimen/space_sm"
                style="@style/IBF.Button.Accent"
                app:icon="@drawable/ic_save" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
