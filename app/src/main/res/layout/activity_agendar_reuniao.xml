<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.agenda.AgendarReuniaoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Agendar Discipulado"
            android:textColor="?attr/colorOnBackground"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Seleção de Membro -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/IBF.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Membro">

            <AutoCompleteTextView
                android:id="@+id/autoCompleteMembro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Data -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Data e Hora"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_data"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Data"
                style="@style/IBF.Button.Secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hora"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Hora"
                style="@style/IBF.Button.Secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_data_selecionada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Nenhuma data selecionada"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <!-- Local -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/IBF.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Local">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_local"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Observações -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/IBF.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Observações (Opcional)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_observacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top|start"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_salvar_reuniao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Agendar Discipulado"
            style="@style/IBF.Button.Accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_convidar_whatsapp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Convidar via WhatsApp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#25D366"
            app:strokeColor="#25D366"
            app:icon="@drawable/ic_share"
            app:iconTint="#25D366"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_adicionar_agenda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Adicionar ao Google Agenda"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#4285F4"
            app:strokeColor="#4285F4"
            app:icon="@drawable/ic_calendar"
            app:iconTint="#4285F4"
            app:cornerRadius="8dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
