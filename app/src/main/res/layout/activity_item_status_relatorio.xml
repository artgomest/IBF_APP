<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_sm"
    style="@style/IBF.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <TextView
            android:id="@+id/item_status_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xs"
            android:text="@string/item_status_data_label_placeholder"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_title_lg"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_status_rede"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_status_rede_label_placeholder"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_md" />

        <TextView
            android:id="@+id/item_status_tipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_status_tipo_label_placeholder"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_md" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>